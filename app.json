{
  "expo": {
    "name": "Wavelength",
    "slug": "wavelength",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7300ff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mattcng.wavelength",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Wavelength needs access to your photos so you can choose a profile picture.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
